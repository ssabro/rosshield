#!/bin/sh
# E35 — snap post-refresh hook (재설계 후).
#
# 호출 시점: snap이 새 revision을 unpack한 직후, **services start 전**.
# 이 시점에는 새 daemon이 아직 시작되지 않았으므로 healthz polling은 architecturally 불가능.
# 본 hook은 catastrophic 무결성 위반(예: binary corruption, configure 값 invalid)만 cover —
# exit != 0이면 snapd가 자동으로 이전 revision으로 복원(snap 표준 rollback).
#
# daemon health 검증은 별 hook(`check-health`)에서 수행 — services start 후 호출.
#
# 설계: docs/design/notes/e35-refresh-rollback-redesign.md §5 Stage 1.

set -e

# 1. binary 무결성 — server binary가 실행 가능 + 비어있지 않음.
SERVER_BIN="$SNAP/bin/rosshield-server"
if [ ! -x "$SERVER_BIN" ]; then
	logger -t rosshield-post-refresh "FATAL: $SERVER_BIN not executable — refusing refresh"
	exit 1
fi
if [ ! -s "$SERVER_BIN" ]; then
	logger -t rosshield-post-refresh "FATAL: $SERVER_BIN is empty — refusing refresh"
	exit 1
fi

# 2. configure 값 sanity — healthz-url이 정의되어 있다면 http(s):// prefix.
# configure hook이 set 시점에 이미 검증하나, 이전 revision에서 set된 값이
# 새 revision의 검증과 충돌 가능성에 대비.
URL="$(snapctl get healthz-url 2>/dev/null || true)"
if [ -n "$URL" ]; then
	case "$URL" in
		http://*|https://*) : ;;
		*)
			logger -t rosshield-post-refresh "FATAL: invalid healthz-url ($URL) — refusing refresh"
			exit 1
			;;
	esac
fi

logger -t rosshield-post-refresh "post-refresh sanity OK — services will start next"
exit 0
