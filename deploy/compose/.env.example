# rosshield Compose 환경 변수 (E11).
# 본 파일을 .env로 복사 후 값 채워 사용 — .env는 git ignored.

# 첫 부팅 시 시드되는 admin 계정 (필수).
ROSSHIELD_ADMIN_EMAIL=admin@example.com
ROSSHIELD_ADMIN_PASSWORD=changeme-very-long-password-123

# 표시용 tenant 이름 (옵션, 기본 "Default Tenant").
ROSSHIELD_TENANT_NAME=My Organization

# 호스트에서 노출할 포트 (옵션, 기본 8080).
ROSSHIELD_PUBLIC_PORT=8080
